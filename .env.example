# ═══════════════════════════════════════════════════════════════
# Karsa ASM — Environment Variables
# Copy to .env and fill in values before running docker compose up
# ═══════════════════════════════════════════════════════════════

# ── Exchange API Keys (Bybit) ─────────────────────────────────

BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=false

# ── PostgreSQL ─────────────────────────────────────────────────

POSTGRES_USER=karsa
POSTGRES_PASSWORD=karsa    # CHANGE IN PRODUCTION
POSTGRES_DB=karsa
POSTGRES_URL=postgresql+asyncpg://karsa:karsa@postgres:5432/karsa

# ── Redis ──────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0

# ── Telegram Bot (optional) ──────────────────────────────────

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Shadow Mode ───────────────────────────────────────────────

SHADOW_MODE_ENABLED=true
SHADOW_SLIPPAGE_PCT=0.0005
SHADOW_TAKER_FEE_PCT=0.00055
SHADOW_MAKER_FEE_PCT=0.0002

# ── 9Router AI Proxy ─────────────────────────────────────────

NINE_ROUTER_BASE_URL=http://127.0.0.1:20128
NINE_ROUTER_AUTH_TOKEN=
NINE_ROUTER_MODEL=karsa-combo

# ── WireGuard VPN (Gluetun) ─────────────────────────────────
# Generate client keys: wg genkey | tee privatekey | wg pubkey > publickey
# On DO droplet: wg set wg0 peer <client_public_key> allowed-ips 10.0.0.2/32

WIREGUARD_PRIVATE_KEY=your_client_private_key_here
WIREGUARD_PUBLIC_KEY=your_server_public_key_here
WIREGUARD_ADDRESSES=10.0.0.2/32
WIREGUARD_ENDPOINT_IP=your_droplet_ip_here
WIREGUARD_ENDPOINT_PORT=51820

# ── Trading ───────────────────────────────────────────────────

SYMBOLS=["BTC/USDT","ETH/USDT","SOL/USDT","XRP/USDT"]
DAILY_DRAWDOWN_LIMIT=-0.02
MIN_LIQUIDITY_USD=10000

# ── Dead Man's Switch (optional) ─────────────────────────────

DEAD_MANS_SWITCH_URL=
DEAD_MANS_SWITCH_INTERVAL=60

# ── Container Role (set by docker-compose, do not edit) ──────

# KARSA_ROLE=data-engine|live|shadow|backtest|commander
