# === Exchange API Keys ===
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# === PostgreSQL ===
POSTGRES_URL=postgresql+asyncpg://karsa:karsa@db:5432/karsa

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Dead Man's Switch (optional) ===
DEAD_MANS_SWITCH_URL=

# === 9Router AI Proxy ===
9ROUTER_BASE_URL=http://127.0.0.1:20129
9ROUTER_AUTH_TOKEN=
9ROUTER_MODEL=claude-haiku-3-5

# === WireGuard VPN (Gluetun) ===
# Generate client keys: wg genkey | tee privatekey | wg pubkey > publickey
# On DO droplet: wg set wg0 peer <client_public_key> allowed-ips 10.0.0.2/32
WIREGUARD_PRIVATE_KEY=your_client_private_key_here
WIREGUARD_PUBLIC_KEY=your_server_public_key_here
WIREGUARD_ADDRESSES=10.0.0.2/32
VPN_ENDPOINT_IP=your_droplet_ip_here
VPN_ENDPOINT_PORT=51820

# Backend subnet for Gluetun FIREWALL_OUTBOUND_SUBNETS (Docker karsa network)
BACKEND_SUBNET=172.28.0.0/16
