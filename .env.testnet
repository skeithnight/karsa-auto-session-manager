# === Karsa Testnet Configuration ===
# Copy to .env and fill in your testnet API keys.
# Bybit testnet: https://testnet.bybit.com/app/user/api-management
# Importers: docker-compose.yml (env_file: .env), app/core/config.py (Settings)
# No schema change — only adds BYBIT_TESTNET flag to existing Settings class.

# === Exchange API Keys (TESTNET) ===
BYBIT_API_KEY=your_testnet_api_key_here
BYBIT_API_SECRET=your_testnet_api_secret_here
BYBIT_TESTNET=true

# === PostgreSQL ===
POSTGRES_URL=postgresql+asyncpg://karsa:karsa@db:5432/karsa

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Dead Man's Switch (optional) ===
DEAD_MANS_SWITCH_URL=

# === 9Router AI Proxy ===
9ROUTER_BASE_URL=http://127.0.0.1:20129
9ROUTER_AUTH_TOKEN=
9ROUTER_MODEL=claude-haiku-3-5

# === WireGuard VPN (Gluetun) ===
# Not needed for testnet — can run without VPN by disabling gluetun
# To disable: change app network_mode from "service:gluetun" to default bridge
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_ADDRESSES=
VPN_ENDPOINT_IP=
VPN_ENDPOINT_PORT=51820

# Backend subnet for Gluetun FIREWALL_OUTBOUND_SUBNETS (Docker karsa network)
BACKEND_SUBNET=172.28.0.0/16
