{
  "title": "ASM - Core Operations",
  "tags": [
    "asm",
    "trading",
    "core"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "uid": "asm-core-ops-mgr",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "\ud83d\udda5\ufe0f System Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 1,
      "title": "ASM Session",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "karsa_asm_session_active",
          "legendFormat": "Active"
        },
        {
          "expr": "karsa_asm_risk_pct",
          "legendFormat": "Risk %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN/OFF",
                  "color": "red"
                },
                "1": {
                  "text": "ACTIVE",
                  "color": "green"
                }
              }
            }
          ]
        }
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 2,
      "title": "VPN Connection",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "karsa_vpn_status",
          "legendFormat": "VPN Status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DISCONNECTED",
                  "color": "red"
                },
                "1": {
                  "text": "CONNECTED",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Bybit Connection",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "karsa_bybit_status",
          "legendFormat": "Bybit API"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "CONNECTED",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "WS Heartbeat Age",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "karsa_heartbeat_age_seconds",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Symbol Universe",
      "type": "stat",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "expr": "karsa_symbol_universe_total",
          "legendFormat": "Valid Symbols"
        },
        {
          "expr": "karsa_symbol_universe_dropped",
          "legendFormat": "Dropped"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 6,
      "title": "AI Decisions",
      "type": "table",
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 6,
        "y": 7
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "grafana-postgresql-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT symbol AS \"Symbol\", (output_json->>'ai_confidence')::numeric AS \"Confidence\", (output_json->>'direction') AS \"AI Result\", (output_json->>'reasoning') AS \"Reason\", decision_type AS \"Type\", TO_CHAR(created_at, 'HH24:MI:SS') AS \"Time\" FROM ai_decisions ORDER BY id DESC LIMIT 10;",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "grafana-postgresql-datasource"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Confidence"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "green",
                      "value": 75
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "AI Result"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "LONG": {
                        "color": "green",
                        "text": "LONG"
                      },
                      "SHORT": {
                        "color": "red",
                        "text": "SHORT"
                      },
                      "FLAT": {
                        "color": "gray",
                        "text": "FLAT"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 11,
      "title": "Signal Confidence",
      "type": "table",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum(karsa_signal_confidence_sum) by (symbol) / sum(karsa_signal_confidence_count) by (symbol)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "legendFormat": "{{symbol}}"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "symbol": "Symbol",
              "Value": "Confidence"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "\ud83d\udcc8 Trading",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      }
    },
    {
      "id": 7,
      "title": "Cash & Balance",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "expr": "karsa_wallet_total_equity_usdt",
          "legendFormat": "Equity"
        },
        {
          "expr": "karsa_wallet_balance_usdt",
          "legendFormat": "Cash"
        },
        {
          "expr": "sum(abs(karsa_position_size * karsa_position_entry_price_usdt))",
          "legendFormat": "Deployed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 8,
      "title": "Position",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "targets": [
        {
          "expr": "count(karsa_position_size != 0)",
          "legendFormat": "Active Positions",
          "instant": true
        },
        {
          "expr": "karsa_asm_max_positions",
          "legendFormat": "Max Positions",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 9,
      "title": "\ud83d\udd34 Live Trading",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "karsa_position_unrealized_pnl_usdt",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "karsa_position_entry_price_usdt",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "karsa_position_size",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "karsa_position_duration_seconds",
          "format": "table",
          "instant": true,
          "refId": "D"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "symbol"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "instance 4": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "job 4": true
            },
            "renameByName": {
              "symbol": "Symbol",
              "Value #A": "uPnL $",
              "Value #B": "Entry Price",
              "Value #C": "Size",
              "Value #D": "Duration (s)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "desc": true,
                "displayName": "uPnL $"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "uPnL $"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 0
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Entry Price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 10,
      "title": "\ud83d\udcdc Trade History",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "grafana-postgresql-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT symbol AS \"Symbol\", side AS \"Side\", entry_price AS \"Entry Price\", exit_price AS \"Exit Price\", pnl AS \"Realized PnL\", (pnl / (amount * entry_price) * 100) AS \"ROI %\", exit_reason AS \"Exit Reason\" FROM trades WHERE exit_time IS NOT NULL ORDER BY exit_time DESC LIMIT 20;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Realized PnL"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 0
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Entry Price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Exit Price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ROI %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    }
  ],
  "schemaVersion": 36
}
