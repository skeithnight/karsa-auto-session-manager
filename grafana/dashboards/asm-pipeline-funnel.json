  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Macro Funnel",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Signal Funnel",
      "description": "Volume of signals at each pipeline stage. Healthy funnel narrows gradually.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "displayMode": "gradient",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(karsa_signals_pipeline_attempted_total)",
          "legendFormat": "Universe Attempted"
        },
        {
          "expr": "sum(karsa_signals_entered_pipeline_total)",
          "legendFormat": "Entered Pipeline"
        },
        {
          "expr": "sum(karsa_signals_generated_total)",
          "legendFormat": "Signals Generated"
        },
        {
          "expr": "sum(karsa_signal_confidence_passed_total)",
          "legendFormat": "Confidence Passed"
        },
        {
          "expr": "sum(karsa_risk_gate_pass_total)",
          "legendFormat": "Risk Gate Pass"
        },
        {
          "expr": "sum(karsa_orders_placed_total)",
          "legendFormat": "Orders Placed"
        }
      ]
    },
    {
      "id": 2,
      "title": "Data Freshness Rate",
      "description": "% of universe symbols with fresh data (age=0). Below 80% signals data pipeline issue.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background"
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "targets": [
        {
          "expr": "count(karsa_data_age_seconds == 0) / count(karsa_data_age_seconds) * 100",
          "legendFormat": "Fresh %"
        }
      ]
    },
    {
      "id": 3,
      "title": "Alpha Hit Rate",
      "description": "% of pipeline symbols passing confidence gate. Low = alpha bridge too selective.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 15 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background"
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 5 },
      "targets": [
        {
          "expr": "sum(karsa_signal_confidence_passed_total) / (sum(karsa_signals_entered_pipeline_total) + 1) * 100",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Risk Gate Pass Rate",
      "description": "% of signals approved by risk gate. Below 20% = risk params too tight.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 40 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background"
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "targets": [
        {
          "expr": "sum(karsa_risk_gate_pass_total) / (sum(karsa_risk_gate_pass_total) + sum(karsa_risk_gate_reject_total) + 1) * 100",
          "legendFormat": "Pass Rate"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top of Funnel",
      "type": "row",
